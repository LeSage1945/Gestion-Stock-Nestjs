enum SourceDette {
  VENTE
  MANUELLE // ← ajouté : dette saisie manuellement (ex: ancienne dette, avant usage du logiciel)
}

model Dette {
  id String @id @default(uuid())

  compteId String
  compte   Compte @relation(fields: [compteId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  venteId String? @unique // ← rendu optionnel : une dette manuelle n'a pas de vente
  vente   Vente?  @relation(fields: [venteId], references: [id])

  source SourceDette @default(VENTE) // ← ajouté : permet de distinguer l'origine

  montantInitial Float
  montantRestant Float

  statut StatutDette @default(EN_COURS)

  creeLe    DateTime @default(now())
  modifieLe DateTime @updatedAt

  remboursements RemboursementDette[]
}

model RemboursementDette {
  id String @id @default(uuid())

  detteId String
  dette   Dette  @relation(fields: [detteId], references: [id], onDelete: Cascade)

  montant         Float
  methodePaiement MethodePaiement
  motif           String?

  creeLe DateTime @default(now())

  mouvementCaisse MouvementCaisse?
}
