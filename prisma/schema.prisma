generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  SUPER_ADMIN_SAGE_066062594
  ADMIN
  VENDEUR
  CAISSIER
}

enum MethodePaiement {
  ESPECE
  MOBILE_MONEY
}

enum StatutAbonnement {
  ACTIF
  INACTIF
  EXPIRE
  BLOQUE
}

enum TypeMouvement {
  ENTREE
  SORTIE
}

enum SourceMouvement {
  VENTE
  ACHAT_STOCK
  MANUEL
}

enum TypeLivraison {
  LIVRAISON
  RETRAIT_BOUTIQUE
}

enum StatutCommande {
  EN_ATTENTE
  CONFIRMEE
  EN_PREPARATION
  EN_LIVRAISON
  LIVREE
  ANNULEE
}

enum StatutPaiementCommande {
  EN_ATTENTE
  PAYE
  ECHEC
}

enum OperateurMobileMoney {
  MTN
  AIRTEL
  ORANGE
}

model Compte {
  id   String @id @default(uuid())
  code String @unique
  nom  String

  logoUrl            String?
  description        String?
  adresse            String?
  ville              String?
  visibleMarketplace Boolean @default(false)

  categorieId String?
  categorie   Categorie? @relation(fields: [categorieId], references: [id])

  creeLe DateTime @default(now())

  abonnement Abonnement?

  utilisateurs     Utilisateur[]
  produits         Produit[]
  fournisseurs     Fournisseur[]
  ventes           Vente[]
  mouvementsCaisse MouvementCaisse[]
  commandes        Commande[] // ← ajouter
}

model Utilisateur {
  id String @id @default(uuid())

  nom        String
  email      String
  motDePasse String

  role   Role     @default(VENDEUR)
  creeLe DateTime @default(now())

  compteId String
  compte   Compte @relation(fields: [compteId], references: [id])

  ventes Vente[]           @relation("UtilisateurVentes")
  logs   JournalActivite[] @relation("UtilisateurLogs")
}

model Produit {
  id String @id @default(uuid())

  compteId String
  compte   Compte @relation(fields: [compteId], references: [id])

  nom         String
  marque      String
  prix        Float
  seuilAlerte Int

  imageUrl        String? // ← ajouter (pour les images produits du e-commerce)
  description     String? // ← ajouter (description publique pour la boutique)
  visibleBoutique Boolean @default(true) // ← ajouter (afficher ou non sur la vitrine)

  creeLe DateTime @default(now())

  entreesStock   EntreeStock[]
  sortiesStock   SortieStock[]
  lignesVente    LigneVente[]
  alertes        AlerteStock[]
  ligneCommandes LigneCommande[]
}

model Fournisseur {
  id String @id @default(uuid())

  compteId String
  compte   Compte @relation(fields: [compteId], references: [id])

  nom       String
  telephone String?
  adresse   String?
  creeLe    DateTime @default(now())

  entreesStock EntreeStock[]
}

model EntreeStock {
  id            String   @id @default(uuid())
  produitId     String
  fournisseurId String?
  quantite      Int
  prixAchat     Float
  creeLe        DateTime @default(now())

  produit         Produit          @relation(fields: [produitId], references: [id])
  fournisseur     Fournisseur?     @relation(fields: [fournisseurId], references: [id])
  mouvementCaisse MouvementCaisse? @relation("EntreeMouvement")
}

model Vente {
  id String @id @default(uuid())

  compteId String
  compte   Compte @relation(fields: [compteId], references: [id])

  utilisateurId String
  utilisateur   Utilisateur @relation("UtilisateurVentes", fields: [utilisateurId], references: [id])

  montantTotal Float
  creeLe       DateTime @default(now())

  lignes       LigneVente[]
  paiements    Paiement[]
  sortiesStock SortieStock[]
}

model LigneVente {
  id        String @id @default(uuid())
  venteId   String
  produitId String
  quantite  Int
  prix      Float

  vente   Vente   @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)
}

model Paiement {
  id      String @id @default(uuid())
  venteId String

  montant         Float
  methodePaiement MethodePaiement

  creeLe DateTime @default(now())

  vente Vente @relation(fields: [venteId], references: [id])
}

model SortieStock {
  id        String   @id @default(uuid())
  produitId String
  venteId   String?
  quantite  Int
  raison    String
  creeLe    DateTime @default(now())

  produit Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)
  vente   Vente?  @relation(fields: [venteId], references: [id], onDelete: SetNull)
}

model AlerteStock {
  id        String  @id @default(uuid())
  produitId String  @unique
  produit   Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)

  quantiteActuelle Int
  niveauAlerte     Int
  creeLe           DateTime @default(now())
}

model JournalActivite {
  id String @id @default(uuid())

  utilisateurId String
  utilisateur   Utilisateur @relation("UtilisateurLogs", fields: [utilisateurId], references: [id])

  action      String
  description String
  creeLe      DateTime @default(now())
}

model Abonnement {
  id       String @id @default(uuid())
  compteId String @unique
  compte   Compte @relation(fields: [compteId], references: [id], onDelete: Cascade)

  statut StatutAbonnement @default(INACTIF)
  debut  DateTime?
  fin    DateTime?
  creeLe DateTime         @default(now())
}

model MouvementCaisse {
  id String @id @default(uuid())

  compteId String
  compte   Compte @relation(fields: [compteId], references: [id])

  type    TypeMouvement
  source  SourceMouvement
  montant Float
  motif   String
  creeLe  DateTime        @default(now())

  venteId       String?
  entreeStockId String? @unique

  entreeStock EntreeStock? @relation("EntreeMouvement", fields: [entreeStockId], references: [id])
}

model Commande {
  id String @id @default(uuid())

  compteId String
  compte   Compte @relation(fields: [compteId], references: [id])

  // ===== INFOS CLIENT (sans compte) =====
  clientNom       String
  clientTelephone String

  // ===== LIVRAISON =====
  typeLivraison    TypeLivraison
  adresseLivraison String?
  villeLivraison   String?
  fraisLivraison   Float         @default(0)

  // ===== MONTANTS =====
  sousTotal    Float
  montantTotal Float

  // ===== STATUTS =====
  statutCommande StatutCommande         @default(EN_ATTENTE)
  statutPaiement StatutPaiementCommande @default(EN_ATTENTE)

  // ===== NOTES =====
  notesClient String?

  creeLe    DateTime @default(now())
  modifieLe DateTime @updatedAt

  lignes    LigneCommande[]
  paiements PaiementCommande[]
}

model LigneCommande {
  id         String @id @default(uuid())
  commandeId String
  produitId  String
  quantite   Int
  prix       Float

  commande Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit  Produit  @relation(fields: [produitId], references: [id])
}

model PaiementCommande {
  id         String @id @default(uuid())
  commandeId String

  operateur       OperateurMobileMoney
  numeroTelephone String
  montant         Float
  reference       String?
  statut          StatutPaiementCommande @default(EN_ATTENTE)

  creeLe DateTime @default(now())

  commande Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

model Categorie {
  id     String   @id @default(uuid())
  nom    String   @unique
  icone  String?
  ordre  Int      @default(0)
  creeLe DateTime @default(now())

  comptes Compte[]
}